# Copy this file to .env and fill in values.
# All VITE_-prefixed variables are exposed to the browser bundle.

VITE_APP_NAME=FuelMS
VITE_APP_VERSION=0.1.0
VITE_ENABLE_QUERY_DEVTOOLS=true

# GitHub repo slug shown in Settings → Updates (must match tauri.conf.json updater endpoint).
VITE_UPDATER_GITHUB_REPO=your-org/FuelMS

# --- Tauri updater signing (build/release only; NOT exposed to the browser) ---
# Generate keys once:
#   cd apps/desktop && pnpm tauri signer generate -w "%USERPROFILE%\.tauri\fuelms.key"
# Paste the contents of fuelms.key.pub into src-tauri/tauri.conf.json → plugins.updater.pubkey
# Set these as GitHub Actions secrets for release builds:
#   TAURI_SIGNING_PRIVATE_KEY
#   TAURI_SIGNING_PRIVATE_KEY_PASSWORD
